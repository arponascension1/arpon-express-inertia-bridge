{
  "name": "arpon-express-inertia-bridge",
  "version": "1.0.3",
  "description": "Express middleware bridge for Inertia.js with Vite (React + Vue adapter mode)",
  "author": "Arpon",
  "keywords": [
    "express",
    "inertia",
    "inertia.js",
    "express inertia",
    "inertia bridge",
    "react",
    "vue",
    "vue3",
    "vite",
    "middleware",
    "ssr",
    "server-side rendering",
    "spa",
    "single page application",
    "full-stack",
    "isomorphic",
    "typescript",
    "nodejs",
    "adapter"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "release:check": "npm test && npm run build && npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
